# Healthcare RCM Analytics — Environment Configuration
# Copy this file to .env and fill in your values.  All variables are optional unless marked REQUIRED.

# ── AI Assistant ──────────────────────────────────────────────────────────────

# REQUIRED for the AI Assistant tab.  All other tabs work without this key.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM model to use via OpenRouter.  See the Configuration Reference in README.md for model options.
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Maximum rows returned per AI SQL query (min 10).
# AI_MAX_ROWS=100

# Maximum tool-call loop iterations per AI turn (min 1).
# AI_MAX_ITERATIONS=8


# ── Cube Semantic Layer ───────────────────────────────────────────────────────

# REST API URL for the Cube semantic layer service.
# CUBE_API_URL=http://localhost:4000/cubejs-api/v1

# Shared secret for Cube JWT authentication.  Use a strong random value in production.
CUBE_API_SECRET=change_me_before_deploying


# ── Neo4j Knowledge Graph ─────────────────────────────────────────────────────

# Bolt connection URI for the Neo4j instance.
# NEO4J_URI=bolt://localhost:7687

# Neo4j username.
NEO4J_USER=neo4j

# Neo4j password.  Use a strong value in production.
NEO4J_PASSWORD=change_me_before_deploying


# ── Database ──────────────────────────────────────────────────────────────────

# Path to the DuckDB database file.
# RCM_DB_PATH=./data/rcm_analytics.db

# Directory containing the CSV source files used by the ETL pipeline.
# RCM_DATA_DIR=./data/


# ── Streamlit ─────────────────────────────────────────────────────────────────

# TCP port the dashboard listens on.
# STREAMLIT_SERVER_PORT=8501

# Bind address — set to 0.0.0.0 to accept external connections (e.g. Docker).
# STREAMLIT_SERVER_ADDRESS=localhost

# Set to false to disable Streamlit's anonymous usage statistics.
# STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
