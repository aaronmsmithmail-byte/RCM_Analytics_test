# Healthcare RCM Analytics — Environment Configuration
# ======================================================
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# The .env file is listed in .gitignore and will never be committed.
# .env.example IS committed — keep it up to date when you add new variables.
#
# All variables below are optional unless marked REQUIRED.


# ── AI Assistant (Tab 12) ──────────────────────────────────────────────────────

# REQUIRED for the AI Assistant tab.  All other tabs work without this key.
# Get a free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM model to use via OpenRouter (default: openai/gpt-4o-mini).
# Any model listed at https://openrouter.ai/models works here.
# Cost/quality trade-offs:
#   openai/gpt-4o-mini          — fast, cheap, good for most RCM questions
#   openai/gpt-4o               — slower, more expensive, best reasoning
#   anthropic/claude-3-5-sonnet — excellent for long structured answers
#   google/gemini-flash-1.5     — fast, cheap Google alternative
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Maximum rows the AI tool may return per SQL query (default: 100).
# Lower this to reduce LLM token usage; raise it for wider result sets.
# Values below 10 are clamped to 10 automatically.
# AI_MAX_ROWS=100

# Maximum tool-call loop iterations per conversational turn (default: 8).
# Each iteration is one SQL query + one LLM call.  Raise this to let the
# AI chain more queries per question; lower it to reduce latency and cost.
# AI_MAX_ITERATIONS=8


# ── Cube Semantic Layer ──────────────────────────────────────────────────────
# Cube provides the semantic layer (measures, dimensions, joins) for metric
# queries. When available, metrics are routed through Cube instead of raw SQL.
# Run via Docker Compose: docker compose up

# Cube REST API URL (default: http://localhost:4000/cubejs-api/v1)
# CUBE_API_URL=http://localhost:4000/cubejs-api/v1

# Cube API secret — docker-compose.yml reads this value via ${CUBE_API_SECRET}.
# Use a long random string in production (e.g. openssl rand -hex 32).
CUBE_API_SECRET=change_me_before_deploying


# ── Neo4j Knowledge Graph ───────────────────────────────────────────────────
# Neo4j stores the entity-relationship knowledge graph (10 entities, 9 FKs).
# When available, the AI system prompt and Knowledge Graph page pull from Neo4j.
# Run via Docker Compose: docker compose up

# Neo4j Bolt URI (default: bolt://localhost:7687)
# NEO4J_URI=bolt://localhost:7687

# Neo4j credentials — docker-compose.yml reads NEO4J_PASSWORD via ${NEO4J_PASSWORD}.
# NEO4J_USER is almost always "neo4j" (the default Neo4j admin username).
# Use a strong password in production.
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_before_deploying


# ── Database ───────────────────────────────────────────────────────────────────

# Path to the DuckDB database file (default: ./data/rcm_analytics.db).
# Override this when the database lives outside the project directory, e.g.:
#   - Docker volume mount:  /data/rcm_analytics.db
#   - Shared network path:  /mnt/rcm/rcm_analytics.db
# RCM_DB_PATH=/path/to/rcm_analytics.db

# Directory containing the CSV source files (default: ./data/).
# Used by generate_sample_data.py when writing CSVs and by the ETL pipeline
# when loading them into the Bronze layer.
# Override when your data files live outside the project directory.
# RCM_DATA_DIR=/path/to/data/


# ── Streamlit ──────────────────────────────────────────────────────────────────
# These are standard Streamlit environment variables — see:
# https://docs.streamlit.io/develop/api-reference/configuration/config.toml
# They are read directly by Streamlit, not by this application.

# TCP port the dashboard listens on (default: 8501).
# STREAMLIT_SERVER_PORT=8501

# Network interface to bind to (default: localhost).
# Set to 0.0.0.0 to accept connections from any host (useful in Docker).
# STREAMLIT_SERVER_ADDRESS=localhost

# Disable Streamlit's anonymous usage statistics (recommended for production).
# STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
